# ─────────────────────────────────────────────────────────────────────────────
# SecureMail-Ai — STANDALONE mode
# Use: cd SecureMail-Ai && ./setup.sh  (Mac/Linux)
#              OR               setup.bat   (Windows)
# ─────────────────────────────────────────────────────────────────────────────

# Groq LLM API key — get it from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# gRPC server configuration
AI_PORT=50051
AI_MAX_CONCURRENT=4
AI_MAX_BODY_CHARS=120000

# Performance & Logging
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
