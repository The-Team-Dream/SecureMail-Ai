# ─────────────────────────────────────────────────────────────────────────────
# SecureMail-Ai — FULL STACK (Docker network) mode
# HOW TO USE: cp .env.docker.example .env.docker
#             OR just run the root setup.sh / setup.bat
# ─────────────────────────────────────────────────────────────────────────────

# Groq LLM API key — get it from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# gRPC server configuration
AI_PORT=50051
AI_MAX_CONCURRENT=4
AI_MAX_BODY_CHARS=120000

# Performance & Logging
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
